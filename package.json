{
  "name": "planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write .",
    "db:migrate": "tsx run-migrations.ts",
    "db:seed": "tsx seed.ts",
    "db:verify": "ts-node verify-connection.ts",
    "db:generate": "tsx ./node_modules/typeorm/cli.js migration:generate src/migrations/InitialMigration -d cli-data-source.ts",
    "db:create": "tsx ./node_modules/typeorm/cli.js migration:create src/migrations/CreateMigration",
    "neon:auth": "neonctl auth",
    "neon:setup": "bash neon-setup.sh",
    "neon:projects": "neonctl projects list",
    "neon:branches": "neonctl branches list",
    "neon:cs": "neonctl connection-string"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "neonctl": "^2.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^50.37.3"
  }
}
